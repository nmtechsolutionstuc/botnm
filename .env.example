# Telegram: token de @BotFather
TELEGRAM_BOT_TOKEN=

# Gemini: API key de Google AI Studio (aistudio.google.com/apikey)
GEMINI_API_KEY=

# Buffer: API key/access token (Configuración -> API en buffer.com)
BUFFER_ACCESS_TOKEN=

# Google Sheets: ID de la planilla de "modos" (está en la URL de la sheet, entre /d/ y /edit)
GOOGLE_SHEET_ID=

# Ruta al JSON de la cuenta de servicio de Google Cloud (uso local, ver README para cómo generarlo)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
# Alternativa para deploy (ej. Render): pegar el contenido completo del JSON acá en vez de usar la ruta de arriba
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Puerto del endpoint /health (Render lo pisa con su propia variable PORT)
PORT=3000

# URL pública del servicio (la que te da Render, ej: https://makebufferbot.onrender.com)
# Se usa para que Buffer pueda descargar las imágenes que genera Gemini.
PUBLIC_BASE_URL=

# Offset horario fijo usado para interpretar "Programar fecha" (Argentina no tiene horario de verano)
TIMEZONE_UTC_OFFSET=-03:00

# Opcionales: pisan los modelos de Gemini usados por defecto
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_TEXT_MODEL=gemini-2.5-flash

# Cloudflare Workers AI: generación/edición de imágenes (/generar, /editar, /mejorar,
# y fallback automático cuando Gemini no puede mejorar la imagen). Ver README para cómo conseguirlos.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Límite de pedidos de imagen (Cloudflare) por usuario, para no gastar la cuota gratis compartida
IMAGE_RATE_LIMIT_MAX=10
IMAGE_RATE_LIMIT_WINDOW_MIN=60

# Prende/apaga /generar, /editar, /mejorar y el fallback de Cloudflare sin tocar código
CLOUDFLARE_IMAGES_ENABLED=true
